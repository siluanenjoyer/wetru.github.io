<!DOCTYPE html>
<html lang="en">
<head>
  <title>Wetru — Articles</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #b0b0b0;
      font-family: Georgia, serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* Top nav */
    header {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-top: 48px;
    }

    h1 {
      font-size: 2.4rem;
      letter-spacing: 4px;
      color: #1a1a1a;
      text-transform: uppercase;
      text-decoration: none;
      cursor: pointer;
    }

    nav {
      margin-top: 28px;
      display: flex;
      gap: 40px;
    }

    nav a {
      text-decoration: none;
      font-size: 1.1rem;
      letter-spacing: 2px;
      color: #1a1a1a;
      text-transform: uppercase;
      padding: 6px 12px;
      border-radius: 4px;
      transition: background-color 0.25s, color 0.25s;
    }

    nav a:hover {
      background-color: #888;
      color: #f5f5f5;
    }

    nav a.active {
      border-bottom: 2px solid #1a1a1a;
    }

    /* Page layout */
    .page {
      width: 100%;
      max-width: 900px;
      display: flex;
      flex: 1;
      margin-top: 48px;
      gap: 48px;
      padding: 0 24px;
    }

    /* Left sidebar — breadcrumb + article list */
    .sidebar {
      width: 180px;
      flex-shrink: 0;
    }

    .breadcrumb {
      font-size: 0.78rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #444;
      margin-bottom: 28px;
      line-height: 1.8;
    }

    .breadcrumb span {
      cursor: pointer;
      color: #1a1a1a;
      transition: color 0.2s;
    }

    .breadcrumb span:hover {
      color: #555;
    }

    .breadcrumb .separator {
      color: #888;
      cursor: default;
      padding: 0 4px;
    }

    .breadcrumb .current {
      color: #555;
      cursor: default;
    }

    .article-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .article-list li {
      font-size: 0.85rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      cursor: pointer;
      color: #1a1a1a;
      padding: 4px 0;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s, color 0.2s;
    }

    .article-list li:hover {
      color: #333;
      border-bottom: 1px solid #555;
    }

    .article-list li.active {
      font-weight: bold;
      border-bottom: 1px solid #1a1a1a;
    }

    /* Main content */
    .content {
      flex: 1;
      padding-bottom: 60px;
    }

    /* Articles index view */
    .articles-index {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .article-card {
      cursor: pointer;
      padding-bottom: 28px;
      border-bottom: 1px solid #999;
      transition: opacity 0.2s;
    }

    .article-card:last-child {
      border-bottom: none;
    }

    .article-card:hover {
      opacity: 0.75;
    }

    .article-card .tag {
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 8px;
    }

    .article-card h2 {
      font-size: 1.3rem;
      letter-spacing: 1px;
      color: #1a1a1a;
      margin-bottom: 10px;
      font-weight: normal;
    }

    .article-card p {
      font-size: 0.88rem;
      color: #333;
      line-height: 1.7;
    }

    /* Single article view */
    .article-single {
      display: none;
    }

    .article-single.visible {
      display: block;
    }

    .articles-index.hidden {
      display: none;
    }

    .article-single .article-tag {
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #555;
      margin-bottom: 12px;
    }

    .article-single h2 {
      font-size: 1.6rem;
      letter-spacing: 1px;
      color: #1a1a1a;
      font-weight: normal;
      margin-bottom: 20px;
      line-height: 1.4;
    }

    .article-single .body {
      font-size: 0.92rem;
      color: #222;
      line-height: 1.85;
      max-width: 580px;
    }

    .article-single .body p + p {
      margin-top: 16px;
    }

    footer {
      margin-bottom: 24px;
      font-size: 0.9rem;
      letter-spacing: 1px;
      color: #6a0dad;
    }
  </style>
</head>
<body>

  <header>
    <span class="title-link" onclick="goHome()"><h1>Wetru</h1></span>
    <nav>
      <a href="index.html">Articles</a>
      <a href="about.html">About</a>
      <a href="contact.html">Contact</a>
    </nav>
  </header>

  <div class="page">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="breadcrumb" id="breadcrumb">
        <span onclick="showIndex()">Articles</span>
      </div>
      <ul class="article-list" id="articleList">
        <li onclick="openArticle(0)">On Silence</li>
        <li onclick="openArticle(1)">The Grey Hours</li>
        <li onclick="openArticle(2)">Still Water</li>
        <li onclick="openArticle(3)">Weight of Things</li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="content">

      <!-- Articles index -->
      <div class="articles-index" id="articlesIndex">
        <div class="article-card" onclick="openArticle(0)">
          <div class="tag">Essay · 3 min</div>
          <h2>On Silence</h2>
          <p>There is a kind of silence that is not the absence of sound but the presence of something else entirely — a thickness in the air that resists naming.</p>
        </div>
        <div class="article-card" onclick="openArticle(1)">
          <div class="tag">Reflection · 4 min</div>
          <h2>The Grey Hours</h2>
          <p>Between 4 and 6 in the morning the world belongs to no one. It is neither night nor day, and in that gap something honest tends to surface.</p>
        </div>
        <div class="article-card" onclick="openArticle(2)">
          <div class="tag">Essay · 2 min</div>
          <h2>Still Water</h2>
          <p>The lake does not try to be still. Stillness is simply what it returns to when nothing disturbs it. This is worth thinking about for a long time.</p>
        </div>
        <div class="article-card" onclick="openArticle(3)">
          <div class="tag">Observation · 5 min</div>
          <h2>Weight of Things</h2>
          <p>Objects accumulate meaning the way rooms accumulate light — slowly, without intention, until one day you notice it has all changed completely.</p>
        </div>
      </div>

      <!-- Individual articles (hidden until clicked) -->
      <div class="article-single" id="article-0">
        <div class="article-tag">Essay · 3 min</div>
        <h2>On Silence</h2>
        <div class="body">
          <p>There is a kind of silence that is not the absence of sound but the presence of something else entirely — a thickness in the air that resists naming. You find it in empty churches, in the minute after an argument, in the pause before someone says something they cannot take back.</p>
          <p>Most people are afraid of it. They fill it with music, with scrolling, with the low hum of something playing in another room. But to sit inside silence, truly inside it, is to discover that you were never as solid as you thought. The edges blur. Something loosens.</p>
          <p>This is not a bad thing. It is, in fact, the whole point.</p>
        </div>
      </div>

      <div class="article-single" id="article-1">
        <div class="article-tag">Reflection · 4 min</div>
        <h2>The Grey Hours</h2>
        <div class="body">
          <p>Between 4 and 6 in the morning the world belongs to no one. It is neither night nor day, and in that gap something honest tends to surface. The thoughts that come are not the thoughts you perform for others. They are raw, slightly embarrassing, and almost always true.</p>
          <p>Writers have known this for centuries. The grey hours are not for productivity — they are for encountering yourself without the armour that daylight requires. You remember things you pretended not to. You want things you normally suppress.</p>
          <p>Set your alarm once, just once, for 4:30 am. Make no plans. See what arrives.</p>
        </div>
      </div>

      <div class="article-single" id="article-2">
        <div class="article-tag">Essay · 2 min</div>
        <h2>Still Water</h2>
        <div class="body">
          <p>The lake does not try to be still. Stillness is simply what it returns to when nothing disturbs it. This is worth thinking about for a long time.</p>
          <p>We spend so much energy trying to manufacture calm — meditations, routines, rituals of control — when perhaps the better question is what we keep throwing into the water. Stillness is not built. It is what remains when you stop disturbing the surface.</p>
        </div>
      </div>

      <div class="article-single" id="article-3">
        <div class="article-tag">Observation · 5 min</div>
        <h2>Weight of Things</h2>
        <div class="body">
          <p>Objects accumulate meaning the way rooms accumulate light — slowly, without intention, until one day you notice it has all changed completely. The mug on your desk is not a mug. It is three years of mornings, a particular winter, someone you used to know.</p>
          <p>We think we own things. But things quietly own us back. They hold our history in their weight, their scratch marks, the way they fit into a hand that has changed shape since it first picked them up.</p>
          <p>To throw something away is sometimes an act of courage. To keep it is sometimes a kindness to yourself. The difficult part is learning to know the difference before it is too late, and to make peace with the fact that you will often get it wrong.</p>
        </div>
      </div>

    </main>
  </div>

  <footer>wetru.github.io</footer>

  <script>
    const articles = [
      { title: 'On Silence' },
      { title: 'The Grey Hours' },
      { title: 'Still Water' },
      { title: 'Weight of Things' },
    ];

    let currentArticle = null;

    function openArticle(index) {
      // Hide index
      document.getElementById('articlesIndex').classList.add('hidden');

      // Hide any open article
      if (currentArticle !== null) {
        document.getElementById('article-' + currentArticle).classList.remove('visible');
      }

      // Show selected article
      document.getElementById('article-' + index).classList.add('visible');
      currentArticle = index;

      // Update breadcrumb
      document.getElementById('breadcrumb').innerHTML = `
        <span onclick="showIndex()">Articles</span>
        <span class="separator">/</span>
        <span class="current">${articles[index].title}</span>
      `;

      // Update sidebar active state
      const items = document.querySelectorAll('.article-list li');
      items.forEach((li, i) => li.classList.toggle('active', i === index));
    }

    function showIndex() {
      // Hide article
      if (currentArticle !== null) {
        document.getElementById('article-' + currentArticle).classList.remove('visible');
        currentArticle = null;
      }

      // Show index
      document.getElementById('articlesIndex').classList.remove('hidden');

      // Reset breadcrumb
      document.getElementById('breadcrumb').innerHTML = `<span onclick="showIndex()">Articles</span>`;

      // Clear active state
      document.querySelectorAll('.article-list li').forEach(li => li.classList.remove('active'));
    }

    function goHome() {
      window.location.href = 'index.html';
    }
  </script>

</body>
</html>
